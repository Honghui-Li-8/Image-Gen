PORT=3000
NODE_ENV=development
DB_PATH=./db.sqlite
OBSERVABILITY_LOGS=true
ALLOWED_ORIGIN=http://localhost:5173
COMFYUI_MAX_ACTIVE_JOBS=1
COMFYUI_MAX_GLOBAL_ACTIVE_JOBS=10

SEED_USER_1_NAME=user0
SEED_USER_1_PASSWORD=changeme

SEED_USER_2_NAME=user1
SEED_USER_2_PASSWORD=changeme

SEED_USER_3_NAME=user2
SEED_USER_3_PASSWORD=changeme

SEED_USER_4_NAME=user3
SEED_USER_4_PASSWORD=changeme

SEED_USER_5_NAME=user4
SEED_USER_5_PASSWORD=changeme

# [port must match proxy/.env PROXY_PORT when running locally]
PROXY_URL=http://localhost:3001
# [MUST MATCH proxy/.env PROXY_AUTH_SECRET] generate with: openssl rand -hex 32
PROXY_AUTH_SECRET=change-me
# absolute path to the workflow directory; defaults to the bundled workflow/ folder
COMFYUI_WORKFLOW_DIR=
COMFYUI_TIMEOUT_MS=600000
COMFYUI_POLL_INTERVAL_MS=1000
