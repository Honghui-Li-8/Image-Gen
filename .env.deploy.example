# Deploy-time configuration — copy to .env.deploy and fill in values.
# These are NOT runtime secrets for the API or proxy.
# Runtime secrets (JWT, PROXY_AUTH_SECRET, etc.) live in api/.env.production.

# ── AWS credentials ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── app → S3 + CloudFront ─────────────────────────────────────────────────────
# S3 bucket name created during one-time setup (see docs/deployment.md)
APP_S3_BUCKET=

# CloudFront distribution ID (from: aws cloudfront list-distributions)
APP_CF_DISTRIBUTION_ID=

# Public URL of the CloudFront distribution — baked into the frontend build.
# Must match ALLOWED_ORIGIN in api/.env.production.
VITE_API_URL=https://your-api-lightsail-ip-or-domain:3000

# ── api → Lightsail ───────────────────────────────────────────────────────────
# Public IP of the Lightsail instance
API_HOST=

# SSH user (Lightsail Node.js blueprint default)
API_USER=ubuntu

# Path to the Lightsail SSH key downloaded during one-time setup
API_SSH_KEY=~/.ssh/lightsail-image-gen.pem

# Deployment directory on the instance
API_REMOTE_DIR=/home/ubuntu/image-gen-api
